{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.24/MicrosoftTeams.schema.json",
  "manifestVersion": "1.24",
  "version": "1.0.0",
  "id": "${{TEAMS_APP_ID}}",
  "developer": {
    "name": "CopilotHLS Team",
    "websiteUrl": "https://example.com/copilothls",
    "privacyUrl": "https://example.com/copilothls/privacy",
    "termsOfUseUrl": "https://example.com/copilothls/terms"
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "accentColor": "#2F6FED",
  "composeExtensions": [],
  "permissions": [
    "identity",
    "messageTeamMembers"
  ],
  "copilotAgents": {
    "declarativeAgents": [
      {
        "id": "declarativeAgent",
        "file": "declarativeAgent.json"
      }
    ]
  },
  "validDomains": [],
  "name": {
    "short": "CopilotHLS-${{APP_NAME_SUFFIX}}",
    "full": "CopilotHLS Life Sciences Orchestrator"
  },
  "description": {
    "short": "Primary life sciences copilot for research, protocol, and compliance triage.",
    "full": "Primary CopilotHLS declarative agent that routes life sciences questions across literature research, protocol drafting, compliance review, data analysis triage, and approved enterprise knowledge sources."
  }
}
