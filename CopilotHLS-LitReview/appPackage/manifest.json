{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.24/MicrosoftTeams.schema.json",
  "manifestVersion": "1.24",
  "version": "1.0.0",
  "id": "${{TEAMS_APP_ID}}",
  "developer": {
    "name": "CopilotHLS Team",
    "websiteUrl": "https://example.com/copilothls",
    "privacyUrl": "https://example.com/copilothls/privacy",
    "termsOfUseUrl": "https://example.com/copilothls/terms"
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "accentColor": "#2F6FED",
  "composeExtensions": [],
  "permissions": [
    "identity",
    "messageTeamMembers"
  ],
  "copilotAgents": {
    "declarativeAgents": [
      {
        "id": "declarativeAgent",
        "file": "declarativeAgent.json"
      }
    ]
  },
  "validDomains": [],
  "name": {
    "short": "LitReview-${{APP_NAME_SUFFIX}}",
    "full": "CopilotHLS Literature Review Specialist"
  },
  "description": {
    "short": "Systematic literature review agent for biomedical evidence gathering.",
    "full": "Specialist literature review agent for PubMed-led evidence gathering, citation mapping, review-method guidance, and bibliometric analysis on approved research topics."
  }
}
