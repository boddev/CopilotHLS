{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.24/MicrosoftTeams.schema.json",
  "manifestVersion": "1.24",
  "version": "1.0.0",
  "id": "${{TEAMS_APP_ID}}",
  "developer": {
    "name": "CopilotHLS Team",
    "websiteUrl": "https://example.com/copilothls",
    "privacyUrl": "https://example.com/copilothls/privacy",
    "termsOfUseUrl": "https://example.com/copilothls/terms"
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "accentColor": "#2F6FED",
  "composeExtensions": [],
  "permissions": [
    "identity",
    "messageTeamMembers"
  ],
  "copilotAgents": {
    "declarativeAgents": [
      {
        "id": "declarativeAgent",
        "file": "declarativeAgent.json"
      }
    ]
  },
  "validDomains": [],
  "name": {
    "short": "VeevaQualityDocs-${{APP_NAME_SUFFIX}}",
    "full": "CopilotHLS Veeva QualityDocs Specialist"
  },
  "description": {
    "short": "Veeva QualityDocs agent for quality document management and GxP compliance.",
    "full": "Specialist agent for searching, reviewing, and analyzing quality management documents stored in the Veeva QualityDocs vault via the Microsoft Graph Connector."
  }
}
