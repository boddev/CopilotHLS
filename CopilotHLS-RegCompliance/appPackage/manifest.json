{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.24/MicrosoftTeams.schema.json",
  "manifestVersion": "1.24",
  "version": "1.0.0",
  "id": "${{TEAMS_APP_ID}}",
  "developer": {
    "name": "CopilotHLS Team",
    "websiteUrl": "https://example.com/copilothls",
    "privacyUrl": "https://example.com/copilothls/privacy",
    "termsOfUseUrl": "https://example.com/copilothls/terms"
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "accentColor": "#2F6FED",
  "composeExtensions": [],
  "permissions": [
    "identity",
    "messageTeamMembers"
  ],
  "copilotAgents": {
    "declarativeAgents": [
      {
        "id": "declarativeAgent",
        "file": "declarativeAgent.json"
      }
    ]
  },
  "validDomains": [],
  "name": {
    "short": "RegCompliance-${{APP_NAME_SUFFIX}}",
    "full": "CopilotHLS Regulatory Compliance Specialist"
  },
  "description": {
    "short": "Regulatory compliance agent for FDA, EMA, ICH, and Veeva RIM-grounded work.",
    "full": "Specialist regulatory compliance agent for grounded FDA, EMA, ICH, ClinicalTrials.gov, and Veeva RIM-supported research and submission-preparation tasks."
  }
}
